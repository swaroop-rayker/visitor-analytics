# Public application
APP_ENV=development
PUBLIC_BASE_URL=http://localhost
REDIRECT_TARGET_URL=https://www.instagram.com/your_profile/
TRUSTED_HOSTS=analytics.example.com,localhost,127.0.0.1

# Generate long random values before deployment:
# openssl rand -hex 32
JWT_SECRET=replace-with-at-least-32-random-characters
FINGERPRINT_SECRET=replace-with-a-different-random-secret
ADMIN_USERNAME=admin
# Generate with: docker compose run --rm backend python -m app.cli hash-password
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD=change-me-for-first-start-only

# Storage and retention
DATABASE_URL=sqlite:////data/analytics.db
RAW_RETENTION_DAYS=45
BACKUP_RETENTION_COUNT=30
BACKUP_HOUR_UTC=2

# Download GeoLite2 City and ASN databases from MaxMind.
GEOIP_CITY_DB=/geoip/GeoLite2-City.mmdb
GEOIP_ASN_DB=/geoip/GeoLite2-ASN.mmdb

# Security / reverse proxy
ACCESS_TOKEN_MINUTES=480
LOGIN_RATE_LIMIT_PER_MINUTE=5
TRACK_RATE_LIMIT_PER_MINUTE=30
FORWARDED_ALLOW_IPS=127.0.0.1
